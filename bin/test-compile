#!/usr/bin/env bash
# usage: bin/test-compile <build-dir> <cache-dir> <env-dir>

set -euo pipefail

build="${1}"
cache="${2}"
env_dir="${3}"
BUILDPACK_DIR=$(cd "$(dirname "$(dirname "${BASH_SOURCE[0]}")")" && pwd)

echo "true" >"${env_dir}/GO_INSTALL_TOOLS_IN_IMAGE"
echo "true" >"${env_dir}/GO_SETUP_GOPATH_FOR_MODULE_CACHE"

source "${BUILDPACK_DIR}/bin/compile" "${build}" "${cache}" "${env_dir}"

if [[ -f "${build}/.golangci.yml" ]] || [[ -f "${build}/.golangci.toml" ]] || [[ -f "${build}/.golangci.json" ]]; then
	output::step "/.golangci.{yml,toml,json} detected"
	tmp="$(mktemp -d)"
	mkdir -p "${build}/.heroku/golangci/bin"
	ensureFile "golangci-lint-1.20.0-linux-amd64.tar.gz" "${tmp}" "tar -C ${build}/.heroku/golangci/bin --strip-components=1 -zxf"
fi
